<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>Ellen's Memory Lane</string>
	<key>CFBundleName</key>
	<string>EllensMemoryLane</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>

	<!-- Fullscreen, landscape side-scroller. No status bar; the game draws edge
	     to edge and pads its controls for the safe area itself. -->
	<key>UIStatusBarHidden</key>
	<true/>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>
	<key>UIRequiresFullScreen</key>
	<true/>

	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- Loads HTTPS GitHub Pages, so no App Transport Security exception is
	     needed. (The optional local relay for Player 2 uses ws://; add an ATS
	     exception only if you wire that up — see README.) -->

	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
